{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/flow-checkpoint/validate-gates.sh",
        "cwd": ".",
        "env": {
          "GATE_MODE": "warn"
        },
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/flow-checkpoint/checkpoint.sh",
        "cwd": ".",
        "timeoutSec": 30
      }
    ]
  }
}
